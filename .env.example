# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB=mydb

# Schema
PG_SCHEMA=public

# Graph settings
# Partitions for edges table: 8 / 16 / 32 / 64
# Guide:
#   up to 10M edges   → 8
#   10M – 100M edges  → 16
#   100M – 500M edges → 32
#   500M+ edges       → 64
GRAPH_PARTITIONS=16
